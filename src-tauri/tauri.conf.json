{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fit Reporter",
  "version": "0.1.0",
  "identifier": "com.patrik-rybka.fit-reporter",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Fit Reporter",
        "width": 1280,
        "height": 850,
        "minWidth": 1240,
        "minHeight": 750
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost https://*.openstreetmap.org https://*.tile.opentopomap.org https://*.arcgisonline.com data:; connect-src 'self' ipc: http://ipc.localhost https://*.openstreetmap.org https://*.tile.opentopomap.org https://*.arcgisonline.com; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**/*", "$APPCACHE/**/*", "$APPLOCALDATA/**/*"]
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/Patrik-Rybka/fit-reporter/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdDOTUxOTg5NDIwMjE2N0UKUldSK0ZnSkNpUm1WZkN5ZDNoeXZmR0ZPeERMVytIRHFzK29VZTZmb01UcWJoS1ptOGNmRjdrMFcK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "licenseFile": "license.rtf"
  }
}
